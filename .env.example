# Copy this file to .env.local and fill in real values from your Auth0
# Regular Web Application. Do not commit .env.local.

# Generate locally with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH0_SECRET=

# Must match the local dev server origin and the Auth0 dashboard URLs.
AUTH0_BASE_URL=http://localhost:3000

# Example: https://YOUR_AUTH0_DOMAIN.auth0.com
AUTH0_ISSUER_BASE_URL=

# From the Auth0 application's Basic Information section.
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
